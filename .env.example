# -----------------------------------------------------------------------
# worship-catalog environment variables
#
# Copy this file to .env and fill in values as needed.
# .env is gitignored — never commit real credentials.
#
#   cp .env.example .env
# -----------------------------------------------------------------------

# Path to the SQLite database file
# Inside the Docker container this resolves to /data/worship.db (the volume mount).
# For local development outside Docker, use a relative or absolute path.
DB_PATH=data/worship.db

# Directory polled by the watcher service for incoming PPTX files
INBOX_DIR=./inbox

# Log verbosity: DEBUG | INFO | WARNING | ERROR  (default: INFO)
LOG_LEVEL=INFO

# Optional: write logs to a rotating file in addition to stdout.
# The parent directory will be created automatically if it doesn't exist.
# Leave blank (or omit) for stdout-only logging.
# LOG_FILE=logs/worship.log

# Optional: host port the web UI binds to (default: 8000)
# WEB_PORT=8000

# Optional: earliest date the Missing Services report will consider (ISO YYYY-MM-DD).
# Defaults to the first Sunday Highland began collecting data. The report never
# flags gaps before this date, even for wide lookback windows.
# DATA_COLLECTION_START=2026-03-01

# Optional: Vision OCR configuration. OpenRouter is the default provider.
# A configured key also enables score-image OCR for browser uploads.
# WORSHIP_OCR_PROVIDER=openrouter
# WORSHIP_OCR_MODEL=google/gemini-2.5-flash-lite
# WORSHIP_MAX_OCR_CALLS=25
# OPENROUTER_API_KEY=...
# Legacy fallback: set WORSHIP_OCR_PROVIDER=anthropic and ANTHROPIC_API_KEY.
# ANTHROPIC_API_KEY=sk-ant-...

# Optional: Pushover credentials for backup failure alerts.
# When set, backup.sh sends a Pushover notification if the backup fails.
# Get your app token at https://pushover.net/apps and your user key from
# the Pushover home screen. Leave blank to disable alerting.
# PUSHOVER_APP_TOKEN=your-app-token-here
# PUSHOVER_USER_KEY=your-user-key-here
