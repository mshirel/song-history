# Submit-WorshipSlides configuration
# Copy this file to Submit-WorshipSlides.env and fill in values.

# URL of the song-history upload endpoint (Pi on the church LAN)
UPLOAD_URL=https://songs.highland-coc.com/upload

# Root folder containing the year/date subdirectories with PPTX files
# Example: C:\Worship or \\server\worship
WATCH_ROOT=C:\Worship

# Path to the manifest file tracking already-submitted files (optional)
# Defaults to submitted-files.json next to the script
# MANIFEST_PATH=C:\Worship\submitted-files.json

# Path to the log file (optional)
# Defaults to submit-worship-slides.log next to the script
# LOG_PATH=C:\Worship\submit-worship-slides.log
